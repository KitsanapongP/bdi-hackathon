root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript / JavaScript / JSON / Markdown
[*.{ts,tsx,js,jsx,mjs,cjs,json,md}]
indent_style = space
indent_size = 4

# YAML (ถ้าใช้)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# SQL (ถ้าใช้ migrations)
[*.sql]
indent_style = space
indent_size = 4