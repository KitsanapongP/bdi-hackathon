# Environment variables for the backend application
NODE_ENV=development
PORT=8080

# Database configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=yourdatabase

# JWT
JWT_SECRET=your-secret-key-here-min-8-chars

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Email retry queue
SMTP_QUOTA_RETRY_DELAY_MS=3600000
SMTP_RETRY_BATCH_SIZE=200
